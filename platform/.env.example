# Required for the app to run (auth, data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (used for links, sitemap, emails). Production: https://goodies.so
NEXT_PUBLIC_SITE_URL=https://goodies.so

# Optional: override base URLs for app and store (defaults to SITE_URL)
# NEXT_PUBLIC_APP_URL=https://goodies.so
# NEXT_PUBLIC_STORE_URL=https://goodies.so

# Email (Resend). Required for contact form, order/campaign emails
RESEND_API_KEY=re_xxxx
EMAIL_FROM="Goodies <hello@goodies.so>"
REPLY_TO=hello@goodies.so

# Optional: contact form submissions go here (default: site support email)
# CONTACT_FORM_TO=sales@goodies.so

# Optional: scripts (seed, create users) need service role key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Optional: debug logging in development
# ENABLE_DEBUG_LOGGING=true
